@model Biblioteca.Models.EditarLivroViewModel
@{
ViewData["Title"] = "Editar Livro";
}
<div class="container mt-4">
<h1>Editar Livro</h1>
<hr />
<div class="row">
<div class="col-md-6">
<form asp-action="EditarLivro" method="post">
<input type="hidden" asp-for="Id" />
<div class="form-group mb-3">
<label asp-for="Titulo" class="control-label">Título do Livro</label>
<input asp-for="Titulo" class="form-control" />
</div>
<div class="form-group mb-3">
<label asp-for="Genero" class="control-label">Gênero</label>
<input asp-for="Genero" class="form-control" />
</div>
<div class="form-group mb-3">
<label asp-for="NumPaginas" class="control-label">Número de Páginas</label>
<input asp-for="NumPaginas" type="number" class="form-control" />
</div>
<div class="form-group mb-3">
<label asp-for="DataPublicacao" class="control-label">Data de Publicação</label>
<input asp-for="DataPublicacao" type="date" class="form-control" />
</div>
<div class="form-group mb-3">
<label asp-for="AutorId" class="control-label">Autor</label>
<select asp-for="AutorId" class="form-control" asp-items="ViewBag.Autores">
<option value="">-- Selecione um Autor --</option>
</select>
</div>
<div class="form-group mb-3">
<label asp-for="CorCapa" class="control-label">Cor da Capa</label>
<input asp-for="CorCapa" type="color" style="height: 40px; padding: 0;" class="form-control" />
</div>
<div class="form-group mt-4">
<button type="submit" class="btn btn-primary">Salvar Alterações</button>
<a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</div>
</form>
</div>
</div>
</div>
