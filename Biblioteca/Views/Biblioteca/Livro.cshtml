@model Biblioteca.Models.Livro
@{
    ViewData["Title"] = "Detalhes do Livro";
}

@section Styles {
    <link rel="stylesheet" href="~/css/biblioteca.css" />
    <style>
        /* Estilos adicionais para a página do Livro mantendo o padrão biblioteca.css */
        .biblioteca-header-local {
            margin-bottom: 30px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .back-link {
            text-decoration: none;
            color: var(--accent);
            font-size: 1rem;
            margin-bottom: 10px;
            font-weight: 600;
            transition: color 0.2s;
        }

        .back-link:hover {
            color: var(--primary);
        }

        .biblioteca-header-local h2 {
            margin: 0;
            border-bottom: 3px solid var(--accent);
            padding-bottom: 10px;
            color: var(--primary);
            font-weight: 700;
            display: inline-block;
        }

        /* Hero Section no formato original */
        .livro-hero {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 40px;
            background: var(--white);
            padding: 30px;
            border-radius: 12px;
            box-shadow: var(--shadow);
            margin-bottom: 30px;
        }

        .livro-capa-detalhe {
            height: 420px;
            border-radius: 10px;
            position: relative;
            display: flex;
            align-items: flex-end;
            padding: 15px;
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .livro-header-info {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .livro-header-info h1 {
            font-size: 2.2rem;
            margin-top: 0;
            color: var(--primary);
        }

        .autor-nome {
            font-size: 1.1rem;
            color: #7f8c8d;
            margin-bottom: 25px;
        }

        .meta-info {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-bottom: 30px;
            padding: 15px 0;
            border-top: 1px solid #eee;
            border-bottom: 1px solid #eee;
        }

        .meta-item {
            font-size: 0.9rem;
            color: var(--primary);
        }

        /* Autor Estilo */
        .autor-card {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            text-decoration: none;
            color: inherit;
            cursor: pointer;
        }

        .autor-foto-placeholder {
            width: 80px;
            height: 80px;
            background: var(--bg-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            border: 2px solid #eee;
            font-size: 2rem;
        }

        .autor-bio h4 {
            margin: 0 0 5px 0;
            font-size: 1rem;
            color: var(--primary);
        }

        .autor-bio p {
            font-size: 0.85rem;
            margin: 0;
            color: #7f8c8d;
        }

        /* Responsividade */
        @@media (max-width: 768px) {
            .livro-hero { grid-template-columns: 1fr; text-align: center; }
            .livro-capa-detalhe { height: 350px; width: 250px; margin: 0 auto; }
            .meta-info { justify-content: center; }
            .autor-card { flex-direction: column; align-items: center; text-align: center; }
        }
    </style>
}

<div class="page-wrapper">
    <header class="biblioteca-header-local">
        <!-- Rota de volta para o Catálogo -->
        <a href="@Url.Action("Index", "Biblioteca")" class="back-link">
            ← Voltar ao Catálogo
        </a>
        <h2>Detalhes da Obra</h2>
    </header>

    <main class="livro-detalhe-container">
        <section class="livro-hero">
            <div class="livro-capa-detalhe" style="background-color: @Model.CorCapa;">
                <span class="genero-tag">@Model.Genero</span>
            </div>

            <div class="livro-header-info">
                <h1>@Model.Titulo</h1>
                <p class="autor-nome">Por <strong>@(Model.Autor?.Nome ?? "Desconhecido")</strong></p>
                
                <div class="meta-info">
                    <span class="meta-item"><strong>Publicação:</strong> <span>@Model.DataPublicacao.Year</span></span>
                    <span class="meta-item"><strong>Páginas:</strong> <span>@Model.NumPaginas</span></span>
                </div>

                <div>
                    <a asp-action="EditarLivro" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">Editar</a>
                    <a asp-action="DeletarLivro" asp-route-id="@Model.Id" class="btn btn-sm btn-danger">Excluir</a>
                </div>
            </div>
        </section>

        @if (Model.Autor != null)
        {
            <section class="info-secao">
                <div class="info-box">
                    <h3>Sobre o Autor</h3>
                    <a asp-action="Autor" asp-route-id="@Model.Autor.Id" class="autor-card" style="display: block;">
                        <div class="autor-bio">
                            <h4>@Model.Autor.Nome</h4>
                            <p>Clique para ver o perfil do autor.</p>
                        </div>
                    </a>
                </div>
            </section>
        }
    </main>
</div>
