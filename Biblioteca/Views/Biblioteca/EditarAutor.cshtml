@model Biblioteca.Models.EditarAutorViewModel
@{
    ViewData["Title"] = "Editar Autor";
}
<div class="container mt-4">
    <h1>Editar Autor</h1>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="EditarAutor" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="form-group mb-3">
                    <label asp-for="Nome" class="control-label">Nome do Autor</label>
                    <input asp-for="Nome" class="form-control" required />
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Biografia" class="control-label">Biografia</label>
                    <textarea asp-for="Biografia" class="form-control" rows="4" required></textarea>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="DataNascimento" class="control-label">Data de Nascimento</label>
                    <input asp-for="DataNascimento" type="date" class="form-control" required />
                </div>
                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
