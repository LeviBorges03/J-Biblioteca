@model Biblioteca.Models.Autor
@{
    ViewData["Title"] = "Cadastrar Autor";
}

<div class="form-container">
    <h2>Cadastro de Autor</h2>

    <form asp-controller="Biblioteca" asp-action="CriarAutor" method="post">
        <div class="form-group">
            <label asp-for="Nome">Nome do Autor</label>
            <input asp-for="Nome" placeholder="Digite o nome do autor" required />
        </div>

        <div class="form-group">
            <label asp-for="DataNascimento">Data de Nascimento</label>
            <input asp-for="DataNascimento" type="date" required />
        </div>

        <div class="form-group">
            <label asp-for="Biografia">Biografia</label>
            <textarea asp-for="Biografia" rows="4" placeholder="Digite uma breve biografia" required></textarea>
        </div>

        <button type="submit" class="btn-submit">Cadastrar Autor</button>
    </form>
</div>
